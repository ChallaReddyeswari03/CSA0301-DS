Q11 – Searching Records
Linear Search
START
FOR each element
    IF element == key
        Display "Found"
        STOP
END FOR
Display "Not Found"
END
Binary Search
START
Sort data
low = 0
high = n-1
WHILE low <= high
    mid = (low + high)/2
    IF key == data[mid]
        Display "Found"
        STOP
    ELSE IF key < data[mid]
        high = mid-1
    ELSE
        low = mid+1
END WHILE
Display "Not Found"
END

