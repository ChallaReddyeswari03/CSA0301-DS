Q7 – File System (Recursion)
Pseudo Code
FUNCTION DisplayFolder(folder)
    Display folder name
    FOR each item in folder
        IF item is folder
            DisplayFolder(item)
        ELSE
            Display file
        END IF
    END FOR
END FUNCTION

Q8 – Recursion vs Iteration
Recursive
FUNCTION Factorial(n)
    IF n == 0
        RETURN 1
    ELSE
        RETURN n × Factorial(n-1)
END FUNCTION
Iterative
START
fact = 1
FOR i = 1 TO n
    fact = fact × i
END FOR
Display fact
END

